{
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/img/*", "/css/*", "/js/*", "/api/*"]
  }
}
